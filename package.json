{
  "name": "diskloom",
  "version": "2.0.0",
  "private": true,
  "description": "A beautiful, local-first disk space explorer",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc -b && vite build && electron-builder",
    "build:dir": "tsc -b && vite build && electron-builder --dir",
    "typecheck": "tsc -b --pretty",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.diskloom.app",
  "productName": "Diskloom",
    "files": ["dist/**/*", "dist-electron/**/*", "package.json"],
    "mac": { "category": "public.app-category.utilities", "target": "dmg", "icon": "build/icon.png" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage", "category": "Utility" }
  },
  "packageManager": "pnpm@10.32.0"
}
